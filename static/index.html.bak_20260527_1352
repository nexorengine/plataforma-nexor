<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEXOR — Certification Readiness Engine</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#07090f;
  --bg2:#0d1120;
  --bg3:#111827;
  --border:#1a2a45;
  --border2:#243550;
  --blue:#4a8fd4;
  --blue2:#2d6aad;
  --green:#27ae60;
  --red:#c0392b;
  --amber:#d4a017;
  --text:#c8d6e8;
  --text2:#7a9bbf;
  --text3:#3a5575;
}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
.app{max-width:960px;margin:0 auto;padding:0 1rem 3rem;}

/* HEADER */
.hdr{display:flex;align-items:center;gap:12px;padding:1.2rem 0 1rem;border-bottom:1px solid var(--border);margin-bottom:1.5rem;}
.hdr-badge{background:var(--bg2);border:1px solid var(--border2);border-radius:4px;padding:4px 10px;font-size:9px;letter-spacing:2.5px;color:var(--blue);text-transform:uppercase;}
.hdr-title{font-size:11px;color:var(--text2);letter-spacing:1px;flex:1;}
.hdr-ver{font-size:9px;color:var(--text3);letter-spacing:1px;}
.dot{width:6px;height:6px;border-radius:50%;background:#2ecc71;box-shadow:0 0 8px #2ecc71;flex-shrink:0;}

/* SCREENS */
.screen{display:none;}
.screen.active{display:block;}

/* CERT GRID */
.slabel{font-size:9px;letter-spacing:2.5px;color:var(--text3);text-transform:uppercase;margin-bottom:10px;}
.cert-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:2rem;}
.cert-card{background:#000000;border:1px solid var(--border);border-radius:10px;padding:1rem;cursor:pointer;transition:all .2s;position:relative;display:flex;flex-direction:column;align-items:center;text-align:center;}
.cert-card:hover{border-color:var(--blue);background:#111111;}
.cert-top{width:100%;height:3px;position:absolute;top:0;left:0;}
.cert-icon{font-size:28px;margin-bottom:10px;}
.cert-name{font-size:13px;font-weight:bold;color:#e8f0fa;letter-spacing:.5px;margin-bottom:4px;}
.cert-meta{font-size:9px;color:var(--text3);line-height:1.5;}
.cert-badge{display:inline-block;margin-top:8px;background:rgba(74,143,212,.12);border:1px solid rgba(74,143,212,.3);border-radius:3px;padding:2px 8px;font-size:9px;letter-spacing:1px;color:var(--blue);}
.cert-badge-img{width:56px;height:56px;margin-bottom:8px;}

/* DOMAIN LIST */
.back-btn{background:none;border:1px solid var(--border);border-radius:5px;padding:6px 14px;cursor:pointer;font-family:'Inter',sans-serif;font-size:10px;color:var(--text2);letter-spacing:1px;margin-bottom:1.5rem;transition:all .15s;}
.back-btn:hover{border-color:var(--blue);color:var(--blue);}
.cert-header{display:flex;align-items:center;gap:12px;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid var(--border);}
.cert-header-icon{font-size:24px;width:52px;height:52px;display:flex;align-items:center;justify-content:center;}
.cert-header-name{font-size:16px;color:#e8f0fa;font-weight:bold;}
.cert-header-meta{font-size:10px;color:var(--text3);margin-top:2px;}

.domain-list{display:flex;flex-direction:column;gap:10px;margin-bottom:2rem;}
.domain-row{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:1.1rem 1.3rem;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:space-between;}
.domain-row:hover{border-color:var(--blue);background:var(--bg3);}
.domain-row-left{}
.domain-row-name{font-size:13px;color:#e8f0fa;margin-bottom:4px;}
.domain-row-meta{font-size:10px;color:var(--text3);}
.domain-row-right{display:flex;align-items:center;gap:10px;}
.quiz-count-badge{background:var(--bg3);border:1px solid var(--border2);border-radius:4px;padding:4px 10px;font-size:10px;color:var(--text2);}

/* QUIZ LIST */
.quiz-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;margin-bottom:2rem;}
.quiz-tile{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:1rem;cursor:pointer;transition:all .2s;text-align:center;position:relative;}
.quiz-tile:hover{border-color:var(--blue);background:var(--bg3);}
.quiz-tile.saved{border-color:var(--border2);}
.quiz-tile.saved::after{content:'SALVO';position:absolute;top:6px;right:6px;font-size:7px;letter-spacing:1px;color:var(--green);background:rgba(39,174,96,.1);border:1px solid rgba(39,174,96,.3);border-radius:2px;padding:1px 5px;}
.quiz-tile-num{font-size:22px;font-weight:bold;color:var(--blue);margin-bottom:4px;}
.quiz-tile-lbl{font-size:9px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;}
.quiz-tile-q{font-size:10px;color:var(--text2);margin-top:4px;}
.new-quiz-tile{background:none;border:1px dashed var(--border);border-radius:8px;padding:1rem;cursor:pointer;transition:all .2s;text-align:center;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:4px;min-height:90px;}
.new-quiz-tile:hover{border-color:var(--blue);}
.new-quiz-tile span{font-size:10px;color:var(--text3);letter-spacing:1px;}
.lang-btns{display:flex;gap:6px;margin-top:8px;justify-content:center;}
.lang-btn{background:var(--bg3);border:1px solid var(--border2);border-radius:4px;padding:4px 10px;cursor:pointer;font-family:'Inter',sans-serif;font-size:10px;color:var(--text2);transition:all .15s;letter-spacing:1px;}
.lang-btn:hover{border-color:var(--blue);color:var(--blue);}
.lang-btn.pt{border-color:#27ae60;color:#27ae60;}
.lang-btn.en{border-color:#4a8fd4;color:#4a8fd4;}.lang-btn.es{border-color:#ffffff;color:#ffffff;}
.quiz-tile.bilingual{padding-bottom:.7rem;}

/* GENERATING */
.gen-screen{text-align:center;padding:4rem 2rem;}
.gen-icon{font-size:40px;margin-bottom:1rem;}.gen-icon svg{width:80px;height:80px;display:block;margin:0 auto;}
.gen-title{font-size:12px;letter-spacing:2px;color:var(--text2);text-transform:uppercase;margin-bottom:.5rem;}
.gen-sub{font-size:10px;color:var(--text3);margin-bottom:1.5rem;}
.gen-bar{width:260px;height:2px;background:var(--border);margin:0 auto 1rem;border-radius:2px;overflow:hidden;}
.gen-fill{height:100%;background:var(--blue);animation:gp 1.4s ease-in-out infinite;}
@keyframes gp{0%{width:0%;margin-left:0}50%{width:65%;margin-left:15%}100%{width:0%;margin-left:100%}}
.gen-warn{font-size:10px;color:var(--text3);margin-top:1rem;}

/* QUIZ SCREEN */
.quiz-topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;padding-bottom:1rem;border-bottom:1px solid var(--border);}
.quiz-breadcrumb{font-size:10px;color:var(--text3);letter-spacing:1px;}
.quiz-info{display:flex;align-items:center;gap:16px;}
.quiz-counter{font-size:13px;color:var(--blue);font-weight:bold;}
.timer{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);background:var(--bg2);border:1px solid var(--border);border-radius:5px;padding:5px 12px;}
.timer.warning{color:var(--amber);border-color:var(--amber);}
.timer.critical{color:var(--red);border-color:var(--red);animation:blink 1s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.5}}

.progress-bar{height:2px;background:var(--border);border-radius:2px;margin-bottom:1.5rem;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--blue),#2ecc71);border-radius:2px;transition:width .4s ease;}

.q-box{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.5rem;margin-bottom:1.2rem;}
.q-tag{font-size:8px;letter-spacing:2.5px;color:var(--blue);text-transform:uppercase;margin-bottom:10px;}
.q-num{font-size:10px;color:var(--text3);margin-bottom:8px;}
.q-text{font-size:14px;color:#e8f0fa;line-height:1.75;}

.opts{display:flex;flex-direction:column;gap:8px;margin-bottom:1.2rem;}
.opt{background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:12px 16px;cursor:pointer;font-family:'Inter',sans-serif;font-size:12px;color:var(--text2);text-align:left;transition:all .15s;display:flex;align-items:flex-start;gap:12px;line-height:1.55;width:100%;}
.opt:hover:not(:disabled){border-color:var(--blue);color:var(--text);background:var(--bg3);}
.opt:disabled{cursor:default;}
.opt.correct{border-color:var(--green);background:rgba(39,174,96,.08);color:#2ecc71;}
.opt.wrong{border-color:var(--red);background:rgba(192,57,43,.08);color:#e74c3c;}
.opt.reveal{border-color:var(--green);background:rgba(39,174,96,.08);color:#2ecc71;}
.opt-ltr{min-width:18px;font-weight:bold;color:var(--text3);}
.opt.correct .opt-ltr,.opt.reveal .opt-ltr{color:#2ecc71;}
.opt.wrong .opt-ltr{color:#e74c3c;}

.feedback{border-radius:8px;padding:1.2rem 1.5rem;margin-bottom:1.2rem;display:none;line-height:1.7;}
.feedback.ok{background:rgba(39,174,96,.07);border:1px solid var(--green);}
.feedback.err{background:rgba(192,57,43,.07);border:1px solid var(--red);}
.fb-hdr{font-size:9px;letter-spacing:2px;text-transform:uppercase;font-weight:bold;margin-bottom:8px;}
.feedback.ok .fb-hdr{color:var(--green);}
.feedback.err .fb-hdr{color:var(--red);}
.fb-text{font-size:11px;color:var(--text);}

.next-btn{background:var(--bg2);border:1px solid var(--border2);border-radius:6px;padding:10px 24px;cursor:pointer;font-family:'Inter',sans-serif;font-size:10px;color:var(--blue);letter-spacing:2px;text-transform:uppercase;transition:all .15s;display:none;}
/* Custom Tooltip */
.c-tooltip{position:fixed;background:#ffffff;color:#111111;border-radius:6px;padding:8px 12px;font-size:9px;line-height:1.65;min-width:220px;max-width:280px;box-shadow:0 3px 14px rgba(0,0,0,0.35);pointer-events:none;z-index:9999;opacity:0;transition:opacity .2s;border:1px solid #e0e0e0;}
.c-tooltip.visible{opacity:1;}
.c-tooltip-org{font-weight:700;font-size:11px;color:#111;margin-bottom:4px;border-bottom:1px solid #eee;padding-bottom:3px;}
.c-tooltip-sede{font-size:9px;color:#111;margin-bottom:1px;}
.c-tooltip-reach{font-size:9px;color:#111;}
.tts-btn{background:none;border:1px solid var(--border);border-radius:5px;padding:4px 10px;cursor:pointer;font-size:11px;color:var(--text3);transition:all .15s;display:inline-flex;align-items:center;gap:4px;font-family:'Inter',sans-serif;}
.tts-btn:hover{border-color:var(--blue);color:var(--blue);}
.tts-btn.speaking{border-color:var(--green);color:var(--green);}
.tts-row{display:flex;justify-content:flex-end;margin-bottom:6px;}
.tts-row-fb{display:flex;justify-content:flex-end;margin-bottom:8px;}
.opt-tts{background:none;border:none;cursor:pointer;font-size:11px;color:var(--text3);padding:0 4px;transition:all .15s;flex-shrink:0;}
.opt-tts:hover{color:var(--blue);}
.next-btn:hover{border-color:var(--blue);background:var(--bg3);}
.interrupt-btn{background:none;border:1px solid var(--border);border-radius:6px;padding:7px 18px;cursor:pointer;font-family:'Inter',sans-serif;font-size:10px;color:var(--text3);letter-spacing:1.5px;text-transform:uppercase;transition:all .15s;}
.interrupt-btn:hover{border-color:var(--red);color:var(--red);}

/* RESULTS */
.results-wrap{text-align:center;padding:2rem 0;}
.score-ring{width:130px;height:130px;border-radius:50%;margin:0 auto 1.5rem;display:flex;align-items:center;justify-content:center;flex-direction:column;}
.score-ring.pass{background:rgba(39,174,96,.08);border:3px solid var(--green);color:var(--green);}
.score-ring.fail{background:rgba(192,57,43,.08);border:3px solid var(--red);color:var(--red);}
.score-pct{font-size:30px;font-weight:bold;}
.score-lbl{font-size:9px;letter-spacing:1px;color:var(--text3);}
.res-title{font-size:15px;color:#e8f0fa;margin-bottom:6px;}
.res-sub{font-size:11px;color:var(--text3);margin-bottom:.5rem;}
.res-time{font-size:11px;color:var(--text2);margin-bottom:2rem;}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:2rem;}
.stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:1rem;text-align:center;}
.stat-n{font-size:22px;font-weight:bold;color:var(--blue);}
.stat-l{font-size:9px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;margin-top:2px;}
.res-btns{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;}
.rbtn{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:10px 20px;cursor:pointer;font-family:'Inter',sans-serif;font-size:10px;color:var(--text2);letter-spacing:1.5px;text-transform:uppercase;transition:all .15s;}
.rbtn:hover{border-color:var(--blue);color:var(--blue);}

.divider{height:1px;background:var(--border);margin:1.2rem 0;}
.err-msg{font-size:10px;color:var(--red);margin-top:8px;}
.cert-header-meta-version{opacity:0.6;}</style>
</head>
<body>
<div class="app">

<div class="hdr">
  <span class="dot"></span>
  <span class="hdr-badge">NEXOR</span>
  <span class="hdr-title">Certification Readiness Engine | Powered by FractalLearning™</span>
  <span class="hdr-ver">v3.0</span>
</div>

<!-- S1: CERT SELECTION -->
<div class="screen active" id="s-certs">
  <div class="slabel">Selecionar Certificação</div>
  <div class="cert-grid" id="cert-grid"></div>
</div>

<!-- S2: DOMAIN SELECTION -->
<div class="screen" id="s-domains">
  <button class="back-btn" onclick="goTo('s-certs')">← CERTIFICAÇÕES</button>
  <div class="cert-header">
    <div class="cert-header-icon" id="dh-icon"></div>
    <div style="display:flex;align-items:stretch;gap:0;">
      <div style="flex:1;">
        <div class="cert-header-name" id="dh-name"></div>
        <div class="cert-header-meta" id="dh-meta"></div>
      </div>
    </div>
  </div>
  <div class="slabel">Selecionar Domínio</div>
  <div class="domain-list" id="domain-list"></div>
</div>

<!-- S3: QUIZ LIST -->
<div class="screen" id="s-quizzes">
  <button class="back-btn" onclick="goTo('s-domains')">← DOMÍNIOS</button>
  <div class="cert-header">
    <div>
      <div class="cert-header-name" id="qh-domain"></div>
      <div class="cert-header-meta" id="qh-cert"></div>
    </div>
    <div id="qh-badge" style="font-size:42px;margin-left:auto;flex-shrink:0;opacity:0.9;"></div>
  </div>
  <div class="slabel">Quizzes Disponíveis — 50 questões cada</div>
  <div class="quiz-grid" id="quiz-grid"></div>
  <div class="err-msg" id="quiz-err"></div>
</div>

<!-- S4: GENERATING -->
<div class="screen" id="s-gen">
  <div class="gen-screen">
    <div class="gen-icon" id="gen-icon">⚙️</div>
    <div class="gen-title">Gerando Quiz <span id="gen-num"></span></div>
    <div class="gen-sub" id="gen-sub">Consultando base normativa via IA...</div>
    <div class="gen-bar"><div class="gen-fill"></div></div>
    <div class="gen-warn" id="gen-warn">50 questões de nível sênior. Aguarde ~60 segundos.</div>
  </div>
</div>

<!-- S5: QUIZ -->
<div class="screen" id="s-quiz">
  <div class="quiz-topbar">
    <div style="display:flex;align-items:center;gap:12px;">
      <button class="interrupt-btn" onclick="interruptQuiz()">✕ Interromper</button>
      <div id="q-badge" style="font-size:22px;flex-shrink:0;opacity:0.85;"></div>
      <div class="quiz-breadcrumb" id="q-breadcrumb"></div>
    </div>
    <div class="quiz-info">
      <div class="timer" id="timer">⏱ 00:00</div>
      <div class="quiz-counter" id="q-counter">Q 1 / 50</div>
    </div>
  </div>
  <div class="progress-bar"><div class="progress-fill" id="q-progress" style="width:0%"></div></div>
  <div class="q-box">
    <div class="q-tag" id="q-tag"></div>
    <div class="q-num" id="q-num"></div>
    <div class="q-text" id="q-text"></div>
    <div class="tts-row" style="margin-top:10px;">
      <button class="tts-btn" id="tts-all" onclick="ttsReadAll(quiz.questions[quiz.current])">🔊 Ouvir questão</button>
    </div>
  </div>
  <div class="opts" id="opts"></div>
  <div class="feedback" id="feedback">
    <div class="fb-hdr" id="fb-hdr"></div>
    <div class="tts-row-fb"><button class="tts-btn" id="tts-fb" onclick="ttsSpeak(document.getElementById('fb-text').textContent, this)">🔊 Ouvir análise</button></div>
    <div class="fb-text" id="fb-text"></div>
  </div>
  <button class="next-btn" id="next-btn" onclick="nextQ()">PRÓXIMA →</button>
</div>

<!-- S6: RESULTS -->
<div class="screen" id="s-results">
  <div class="results-wrap">
    <div class="score-ring" id="res-ring">
      <div class="score-pct" id="res-pct">0%</div>
      <div class="score-lbl">ACERTO</div>
    </div>
    <div class="res-title" id="res-title"></div>
    <div class="res-sub" id="res-sub"></div>
    <div class="res-time" id="res-time"></div>
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-n" id="st-correct">0</div><div class="stat-l">Corretas</div></div>
      <div class="stat-card"><div class="stat-n" id="st-wrong">0</div><div class="stat-l">Incorretas</div></div>
      <div class="stat-card"><div class="stat-n" id="st-skip">0</div><div class="stat-l">Puladas</div></div>
      <div class="stat-card"><div class="stat-n" id="st-total">50</div><div class="stat-l">Total</div></div>
    </div>
    <div class="res-btns">
      <button class="rbtn" onclick="replayQuiz()">↺ REPETIR QUIZ</button>
      <button class="rbtn" onclick="goTo('s-quizzes');renderQuizList()">↩ OUTROS QUIZZES</button>
      <button class="rbtn" onclick="goTo('s-certs')">⌂ INÍCIO</button>
    </div>
  </div>
</div>

</div>
<div class="c-tooltip" id="c-tooltip"><div class="c-tooltip-org" id="tt-org"></div><div class="c-tooltip-sede" id="tt-sede"></div><div class="c-tooltip-reach" id="tt-reach"></div></div>
<script>

const CERT_ORGS = {
  cissp:        { org:'ISC²', sede:'Virgínia, EUA', reach:'Reconhecimento global — forte em América do Norte, Europa e Ásia-Pacífico' },
  cism:         { org:'ISACA', sede:'Illinois, EUA', reach:'Reconhecimento global — forte em América do Norte, Europa e Ásia' },
  cciso:        { org:'EC-Council', sede:'Albuquerque, EUA', reach:'Predominantemente América do Norte, Oriente Médio e Ásia' },
  cisa:         { org:'ISACA', sede:'Illinois, EUA', reach:'Reconhecimento global — padrão ouro em auditoria de TI worldwide' },
  iso27001_la:  { org:'PECB', sede:'Quebec, Canadá', reach:'Reconhecimento global — forte em Europa, América Latina e África' },
  iso27001_li:  { org:'PECB', sede:'Quebec, Canadá', reach:'Reconhecimento global — forte em Europa, América Latina e África' },
  iso27701_li:  { org:'PECB', sede:'Quebec, Canadá', reach:'Reconhecimento global — especialmente relevante em Europa (GDPR) e Brasil (LGPD)' },
  iso22301_li:  { org:'PECB', sede:'Quebec, Canadá', reach:'Reconhecimento global — forte em Europa, Oriente Médio e América Latina' },
  itil4:        { org:'PeopleCert / AXELOS', sede:'Atenas, Grécia / Londres, Reino Unido', reach:'Reconhecimento global — padrão em gerenciamento de serviços de TI worldwide' },
  crisc:        { org:'ISACA', sede:'Illinois, EUA', reach:'Reconhecimento global — forte em América do Norte, Europa e Ásia' },
  iso27005:     { org:'PECB', sede:'Quebec, Canadá', reach:'Reconhecimento global — forte em Europa, América Latina e África' },
  cobit:        { org:'ISACA', sede:'Illinois, EUA', reach:'Reconhecimento global — padrão em governança de TI corporativa worldwide' },
  cippe:        { org:'IAPP', sede:'Portsmouth, EUA', reach:'Padrão global de privacidade — essencial na Europa (GDPR) e reconhecido worldwide' },
  cipm:         { org:'IAPP', sede:'Portsmouth, EUA', reach:'Reconhecimento global — forte em América do Norte e Europa' },
  cdpse:        { org:'ISACA', sede:'Illinois, EUA', reach:'Reconhecimento global — crescente em América do Norte, Europa e Ásia-Pacífico' },
  grcp:         { org:'OCEG', sede:'Phoenix, EUA', reach:'Predominantemente América do Norte e Europa — crescendo na América Latina' },
  cfe:          { org:'ACFE', sede:'Austin, EUA', reach:'Reconhecimento global — padrão ouro em investigação de fraudes corporativas worldwide' },
