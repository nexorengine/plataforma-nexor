// Tooltip logic
const tt = document.getElementById('c-tooltip');
function ttShow(el, certId) {
  const d = CERT_ORGS[certId];
  if (!d) return;
  document.getElementById('tt-org').textContent = d.org;
  document.getElementById('tt-sede').textContent = 'Sede: ' + d.sede;
  document.getElementById('tt-reach').textContent = d.reach;
  const r = el.getBoundingClientRect();
  tt.style.left = Math.min(r.left, window.innerWidth - 260) + 'px';
  tt.style.top = (r.bottom + 8) + 'px';
  tt.classList.add('visible');
}
function ttHide() { tt.classList.remove('visible'); }

let catalog = [];
let sel = { cert: null, domain: null, quizNum: null, lang: 'pt' };
let quiz = { questions: [], current: 0, correct: 0, wrong: 0, skipped: 0, answered: false, startTime: null, timerInterval: null };

// TTS Engine
let ttsActive = null;
function ttsStop() {
  window.speechSynthesis.cancel();
  document.querySelectorAll('.tts-btn').forEach(b => b.classList.remove('speaking'));
  document.querySelectorAll('.tts-btn').forEach(b => b.textContent = '🔊');
  ttsActive = null;
}
function ttsSpeak(text, btn) {
  if (ttsActive === btn) { ttsStop(); return; }
  ttsStop();
  const lang = sel.lang === 'en' ? 'en-US' : sel.lang === 'es' ? 'es-ES' : 'pt-BR';
  const utt = new SpeechSynthesisUtterance(text); utt.rate=0.87; utt.pitch=1.08; utt.volume=1.0; const voices=window.speechSynthesis.getVoices(); const preferred=voices.find(v=>v.lang===lang&&v.name.includes("Google"))||voices.find(v=>v.lang===lang)||voices.find(v=>v.lang.startsWith(lang.split("-")[0]))||voices[0]; if(preferred)utt.voice=preferred; utt.lang=lang;
  utt.lang = lang;
  utt.rate = 0.92;
  if (btn) { btn.classList.add('speaking'); btn.textContent = '⏹'; ttsActive = btn; }
  utt.onend = () => { if (btn) { btn.classList.remove('speaking'); btn.textContent = '🔊'; } ttsActive = null; };
  window.speechSynthesis.speak(utt);
}
function ttsReadAll(q) {
  const letters = ['A','B','C','D'];
  const full = q.text + '. ' + q.options.map((o,i) => letters[i] + '. ' + o.replace(/^[A-D]\.\s*/,'')).join('. ');
  const btn = document.getElementById('tts-all');
  ttsSpeak(full, btn);
}

async function init() {
  try {
    const r = await fetch('/api/catalog');
    catalog = await r.json();
    renderCerts();
  } catch(e) {
    document.getElementById('cert-grid').innerHTML = '<div style="color:var(--red);font-size:11px;">Erro ao conectar ao servidor.</div>';
  }
}

function goTo(screen) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(screen).classList.add('active');
}

function renderCerts() {
  const g = document.getElementById('cert-grid');
  g.innerHTML = catalog.map(c => {
    const total = c.domains.reduce((a, d) => a + d.quiz_count, 0);
    const badge = CERT_BADGES[c.id] || '';
    return `<div class="cert-card" onclick="selectCert('${c.id}')">
      <div class="cert-top" style="background:${BADGE_COLORS[c.id] || c.color}"></div>
      <div class="cert-badge-img" onmouseenter="ttShow(this,'${c.id}')" onmouseleave="ttHide()">${badge}</div>
      <div class="cert-name">${c.name}</div>
      <div class="cert-meta">${c.domains.length} domínios · ${c.exam_minutes} min</div>
      <div class="cert-badge">${total} quizzes</div>
    </div>`;
  }).join('');
}

function selectCert(id) {
  sel.cert = catalog.find(c => c.id === id);
  const badgeSvg = CERT_BADGES[sel.cert.id] || '';
  document.getElementById('dh-icon').innerHTML = badgeSvg || sel.cert.icon;
  document.getElementById('dh-name').textContent = sel.cert.name;
  const versionSuffix = sel.cert.version ? '  |  ' + sel.cert.version : '';
  document.getElementById('dh-meta').textContent = `${sel.cert.exam_minutes} min · ${sel.cert.exam_questions} questões · ${sel.cert.domains.length} domínios${versionSuffix}`;
  const dhVersion = document.getElementById('dh-version');
  if (dhVersion) {
    dhVersion.style.display = sel.cert.version ? 'flex' : 'none';
    const dhVersionText = document.getElementById('dh-version-text');
    if (dhVersionText) dhVersionText.textContent = sel.cert.version || '';
  }
  renderDomains();
  goTo('s-domains');
}

function renderDomains() {
  const list = document.getElementById('domain-list');
  list.innerHTML = sel.cert.domains.map(d => `
    <div class="domain-row" onclick="selectDomain('${d.id}')">
      <div class="domain-row-left">
        <div class="domain-row-name">${d.name}</div>
        <div class="domain-row-meta">${d.quiz_count} quizzes salvos · 50 questões cada</div>
      </div>
      <div class="domain-row-right">
        <div class="quiz-count-badge">${d.quiz_count > 0 ? d.quizzes.length + ' quiz' + (d.quizzes.length > 1 ? 'zes' : '') : 'nenhum quiz'}</div>
        <span style="color:var(--blue);font-size:16px;">›</span>
      </div>
    </div>`
  ).join('');
}

function selectDomain(id) {
  sel.domain = sel.cert.domains.find(d => d.id === id);
  document.getElementById('qh-domain').textContent = sel.domain.name;
  document.getElementById('qh-cert').textContent = sel.cert.name + ' · 50 questões por quiz';
  const qhBadge = document.getElementById('qh-badge');
  if (qhBadge) {
    const b = CERT_BADGES[sel.cert.id];
    qhBadge.innerHTML = b || '';
    qhBadge.style.fontSize = b ? '38px' : '0';
  }
  renderQuizList();
  goTo('s-quizzes');
}

function renderQuizList() {
  const g = document.getElementById('quiz-grid');
  const quizzes = sel.domain.quizzes || [];
  const bilingual = sel.cert.bilingual || false;
  const nums = quizzes.map(q => typeof q === 'object' ? q.num : q);
  const next = nums.length > 0 ? Math.max(...nums) + 1 : 1;
  let html = quizzes.map(q => {
    const n = typeof q === 'object' ? q.num : q;
    const hasPt = typeof q === 'object' ? q.has_pt : true;
    const hasEn = typeof q === 'object' ? q.has_en : false;
    const hasEs = typeof q === 'object' ? q.has_es : false;
    if (bilingual) {
      return `<div class="quiz-tile saved bilingual">
        <div class="quiz-tile-num">${n}</div>
        <div class="quiz-tile-lbl">QUIZ</div>
        <div class="lang-btns">
          ${hasPt ? `<button class="lang-btn pt" onclick="startQuiz(${n},'pt')">🇧🇷 PT</button>` : ''}
          ${hasEn ? `<button class="lang-btn en" onclick="startQuiz(${n},'en')">🇺🇸 EN</button>` : ''}
          ${hasEs ? `<button class="lang-btn es" onclick="startQuiz(${n},'es')">🇪🇸 ES</button>` : ''}
        </div>
      </div>`;
    } else {
      return `<div class="quiz-tile saved" onclick="startQuiz(${n},'pt')">
        <div class="quiz-tile-num">${n}</div>
        <div class="quiz-tile-lbl">QUIZ</div>
        <div class="quiz-tile-q">50 questões</div>
      </div>`;
    }
  }).join('');
  const genLabel = bilingual ? 'GERAR PT + EN + ES' : 'GERAR NOVO';
  html += `<div class="new-quiz-tile" onclick="generateQuiz(${next})">
    <span style="font-size:22px;color:var(--text3);">＋</span>
    <span>QUIZ ${next}</span>
    <span style="font-size:9px;">${genLabel}</span>
  </div>`;
  g.innerHTML = html;
  document.getElementById('quiz-err').textContent = '';
}

async function generateQuiz(num) {
  sel.quizNum = num;
  goTo('s-gen');
  document.getElementById('gen-num').textContent = '#' + num;
  document.getElementById('gen-sub').textContent = sel.domain.name + ' · ' + sel.cert.name;
  const certBadge = CERT_BADGES[sel.cert.id];
  if (certBadge) {
    document.getElementById('gen-icon').innerHTML = certBadge;
    document.getElementById('gen-icon').style.fontSize = '0';
  } else {
    document.getElementById('gen-icon').innerHTML = '⚙️';
    document.getElementById('gen-icon').style.fontSize = '';
  }
  if (sel.cert.bilingual) {
    document.getElementById('gen-warn').textContent = 'Gerando versões PT + EN + ES. Aguarde ~8 minutos.';
  }
  try {
    const r = await fetch('/api/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ cert_id: sel.cert.id, domain_id: sel.domain.id, quiz_num: num })
    });
    const data = await r.json();
    if (r.ok) {
      // Refresh catalog to get updated quiz list
      const catR = await fetch('/api/catalog');
      catalog = await catR.json();
      const ci = catalog.findIndex(c => c.id === sel.cert.id);
      const di = catalog[ci].domains.findIndex(d => d.id === sel.domain.id);
      sel.cert = catalog[ci];
      sel.domain = catalog[ci].domains[di];
      renderQuizList();
      const lang = sel.cert.bilingual ? 'pt' : 'pt';
      await startQuiz(num, lang);
    } else {
      document.getElementById('quiz-err').textContent = 'Erro ao gerar quiz.';
      goTo('s-quizzes');
    }
  } catch(e) {
    document.getElementById('quiz-err').textContent = 'Erro de conexão.';
    goTo('s-quizzes');
  }
}

async function startQuiz(num, lang) {
  sel.quizNum = num;
  sel.lang = lang || 'pt';
  try {
    const r = await fetch(`/api/quiz/${sel.cert.id}/${sel.domain.id}/${num}/${sel.lang}`);
    const data = await r.json();
    quiz.questions = data.questions;
    quiz.current = 0;
    quiz.correct = 0;
    quiz.wrong = 0;
    quiz.skipped = 0;
    quiz.answered = false;
    quiz.startTime = Date.now();
    if (quiz.timerInterval) clearInterval(quiz.timerInterval);
    const examSecs = Math.round((sel.cert.exam_minutes * 60) / sel.cert.exam_questions * 50);
    quiz.timerInterval = setInterval(() => updateTimer(examSecs), 1000);
    renderQ();
    goTo('s-quiz');
  } catch(e) {
    document.getElementById('quiz-err').textContent = 'Erro ao carregar quiz.';
    goTo('s-quizzes');
  }
}

function updateTimer(totalSecs) {
  const elapsed = Math.floor((Date.now() - quiz.startTime) / 1000);
  const remaining = Math.max(0, totalSecs - elapsed);
  const m = Math.floor(remaining / 60).toString().padStart(2, '0');
  const s = (remaining % 60).toString().padStart(2, '0');
  const t = document.getElementById('timer');
  t.textContent = '⏱ ' + m + ':' + s;
  t.className = 'timer';
  if (remaining <= 60) t.classList.add('critical');
  else if (remaining <= totalSecs * 0.2) t.classList.add('warning');
  if (remaining === 0) { clearInterval(quiz.timerInterval); showResults(); }
}

function renderQ() {
  const q = quiz.questions[quiz.current];
  const total = quiz.questions.length;
  const langLabel = sel.lang === 'en' ? ' 🇺🇸 EN' : sel.lang === 'es' ? ' 🇪🇸 ES' : ' 🇧🇷 PT';
  document.getElementById('q-breadcrumb').textContent = sel.cert.name + ' · ' + sel.domain.name + ' · Quiz #' + sel.quizNum + (sel.cert.bilingual ? langLabel : '');
  const qBadge = document.getElementById('q-badge');
  if (qBadge) {
    const b = CERT_BADGES[sel.cert.id];
    qBadge.innerHTML = b || '';
    qBadge.style.fontSize = b ? '22px' : '0';
    qBadge.title = sel.cert.name;
  }
  document.getElementById('q-counter').textContent = 'Q ' + (quiz.current + 1) + ' / ' + total;
  document.getElementById('q-progress').style.width = (quiz.current / total * 100) + '%';
  document.getElementById('q-tag').textContent = q.tag || sel.domain.name;
  document.getElementById('q-num').textContent = 'QUESTÃO ' + (quiz.current + 1);
  document.getElementById('q-text').textContent = q.text;
  const opts = document.getElementById('opts');
  opts.innerHTML = '';
  ['A','B','C','D'].forEach((l, i) => {
    const btn = document.createElement('button');
    btn.className = 'opt';
    const txt = (q.options[i] || '').replace(/^[A-D]\.\s*/,'');
    btn.innerHTML = `<span class="opt-ltr">${l}.</span><span style="flex:1">${txt}</span><button class="opt-tts" onclick="event.stopPropagation();ttsSpeak('${txt.replace(/'/g,"\'")}',this)" title="Ouvir alternativa">🔊</button>`;
    btn.onclick = () => answer(i);
    opts.appendChild(btn);
  });
  const fb = document.getElementById('feedback');
  fb.style.display = 'none';
  fb.className = 'feedback';
  document.getElementById('next-btn').style.display = 'none';
  quiz.answered = false;
}

function answer(chosen) {
  if (quiz.answered) return;
  quiz.answered = true;
  const q = quiz.questions[quiz.current];
  const btns = document.querySelectorAll('.opt');
  btns.forEach(b => b.disabled = true);
  if (chosen === q.correct) {
    btns[chosen].classList.add('correct');
    quiz.correct++;
    showFeedback(true, q);
  } else {
    btns[chosen].classList.add('wrong');
    btns[q.correct].classList.add('reveal');
    quiz.wrong++;
    showFeedback(false, q);
  }
  document.getElementById('next-btn').style.display = 'inline-block';
}

function showFeedback(ok, q) {
  const fb = document.getElementById('feedback');
  fb.style.display = 'block';
  fb.className = 'feedback ' + (ok ? 'ok' : 'err');
  document.getElementById('fb-hdr').textContent = ok ? '✓ CORRETO' : '✗ INCORRETO';
  document.getElementById('fb-text').textContent = ok ? q.justification_correct : q.justification_wrong;
}

function nextQ() {
  ttsStop();
  quiz.current++;
  if (quiz.current >= quiz.questions.length) { clearInterval(quiz.timerInterval); showResults(); }
  else renderQ();
}

function showResults() {
  clearInterval(quiz.timerInterval);
  const total = quiz.questions.length;
  const elapsed = Math.floor((Date.now() - quiz.startTime) / 1000);
  const pct = Math.round(quiz.correct / total * 100);
  const pass = pct >= 70;
  const ring = document.getElementById('res-ring');
  ring.className = 'score-ring ' + (pass ? 'pass' : 'fail');
  document.getElementById('res-pct').textContent = pct + '%';
  document.getElementById('res-title').textContent = pass ? 'APROVADO — Nível Sênior' : 'REVISAR — Estudo Adicional Necessário';
  document.getElementById('res-sub').textContent = sel.domain.name + ' · Quiz #' + sel.quizNum;
  const mm = Math.floor(elapsed/60).toString().padStart(2,'0');
  const ss = (elapsed%60).toString().padStart(2,'0');
  document.getElementById('res-time').textContent = 'Tempo: ' + mm + ':' + ss;
  document.getElementById('st-correct').textContent = quiz.correct;
  document.getElementById('st-wrong').textContent = quiz.wrong;
  document.getElementById('st-skip').textContent = total - quiz.correct - quiz.wrong;
  document.getElementById('st-total').textContent = total;
  goTo('s-results');
}

function interruptQuiz() {
  ttsStop();
  clearInterval(quiz.timerInterval);
  quiz.questions = [];
  quiz.current = 0;
  quiz.correct = 0;
  quiz.wrong = 0;
  quiz.answered = false;
  renderQuizList();
  goTo('s-quizzes');
}

function replayQuiz() { startQuiz(sel.quizNum, sel.lang); }

init();
</script>
