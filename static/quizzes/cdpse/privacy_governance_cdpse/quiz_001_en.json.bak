  "questions": [
    {
      "num": 1,
      "text": "Under GDPR Article 4(11), what is the primary distinction between a Data Controller and a Data Processor?",
      "tag": "GDPR Roles and Responsibilities",
      "options": [
        "A. The Controller determines purposes and means of processing; the Processor processes data on behalf of the Controller",
        "D. The Controller is liable for fines; the Processor has no accountability",
        "C. The Controller is always external; the Processor is always internal to the organization",
        "B. The Controller only collects data; the Processor stores and manages it"
      ],
      "correct": 0,
      "justification_correct": "GDPR Article 4(7) and 4(8) define Controller as determining purposes/means, and Processor as processing on Controller's instructions. This foundational distinction establishes accountability hierarchy and compliance responsibilities essential for privacy governance implementation.",
      "justification_wrong": "Incorrect because GDPR establishes joint liability, Processors can be internal/external, and both have distinct obligations. Controller-Processor relationship is contractual and functional, not based on data collection vs. storage dichotomy alone."
    },
    {
      "num": 2,
      "text": "Which framework provides the most comprehensive guidance for implementing privacy-by-design principles aligned with GDPR Article 25?",
      "tag": "Privacy Frameworks and Standards",
      "options": [
        "D. ITIL v4 service management",
        "A. NIST Cybersecurity Framework (CSF) 2.0",
        "B. ISO/IEC 27701:2019 Information security, privacy and trust",
        "C. COBIT 2019 governance framework"
      ],
      "correct": 2,
      "justification_correct": "ISO/IEC 27701 explicitly addresses privacy controls extending ISO 27001, incorporating GDPR Article 25 (privacy-by-design) and providing normative privacy controls. It harmonizes with NIST Privacy Framework while providing technical implementation guidance for privacy engineering.",
      "justification_wrong": "NIST CSF 2.0 focuses on cybersecurity; COBIT addresses IT governance; ITIL manages service operations. While complementary, none directly align with GDPR Article 25 privacy-by-design mandates with the specificity of ISO/IEC 27701."
    },
    {
      "num": 3,
      "text": "Under LGPD (Lei Geral de Proteção de Dados), what is the legal basis for processing personal data when consent is NOT provided?",
      "tag": "LGPD Legal Bases",
      "options": [
        "A. Only data controllers' legitimate interest, without exception",
        "B. Legal or regulatory obligation, contract execution, or vital interest protection",
        "C. Processing is prohibited unless explicit written consent exists",
        "D. Marketing purposes with prior notification to data subjects"
      ],
      "correct": 1,
      "justification_correct": "LGPD Article 7 establishes ten legal bases including compliance with legal obligation (Art. 7, II), contract necessity (Art. 7, III), and vital interest (Art. 7, IV). These provide legitimate processing grounds independent of consent under Brazilian privacy law.",
      "justification_wrong": "LGPD requires one of ten enumerated legal bases; legitimate interest alone is insufficient without meeting Article 7 criteria. Consent prohibition is overstated—LGPD allows alternative bases. Marketing requires legitimate basis, not mere notification."
    },
    {
      "num": 4,
      "text": "What is the primary objective of conducting a Privacy Impact Assessment (PIA) under GDPR Article 35?",
      "tag": "Privacy Impact Assessments",
      "options": [
        "C. To replace the need for Data Protection Officer appointments",
        "B. To identify and mitigate privacy risks before high-risk processing implementation",
        "D. To demonstrate that data processing is technologically impossible to breach",
        "A. To calculate financial penalties for non-compliance"
      ],
      "correct": 1,
      "justification_correct": "GDPR Article 35(1) mandates Data Protection Impact Assessments (DPIA) to assess likelihood and severity of high-risk processing risks. This preventive governance mechanism enables organizations to implement safeguards before deployment.",
      "justification_wrong": "PIAs do not calculate penalties (regulatory function), do not replace DPO appointment (Article 37 requirement), and cannot guarantee breach impossibility. Risk mitigation through assessment is the core objective, not technical infallibility demonstration."
    },
    {
      "num": 5,
      "text": "Under PIPEDA, which principle establishes that personal information collection, use, and disclosure must be limited to identified purposes?",
      "tag": "PIPEDA Principles",
      "options": [
        "D. Principle 4 - Limiting Collection",
        "C. Principle 3 - Consent",
        "B. Principle 2 - Identifying Purposes",
        "A. Principle 1 - Accountability"
      ],
      "correct": 2,
      "justification_correct": "PIPEDA Principle 2 (Schedule 1, Part 1) requires organizations to identify and communicate collection purposes before or at collection time, establishing the foundational constraint for lawful processing scope and consent validity.",
      "justification_wrong": "Principle 1 assigns organizational responsibility; Principle 3 addresses consent mechanics; Principle 4 limits collection methods. Identifying purposes (Principle 2) is the prerequisite that enables all subsequent use limitations and accountability."
    },
    {
      "num": 6,
      "text": "Under GDPR Article 5, which principle requires that personal data be processed in a manner that ensures appropriate security, including protection against unauthorized or unlawful processing?",
      "tag": "GDPR Core Principles",
      "options": [
        "D. Data Minimization",
        "B. Lawfulness and Fairness",
        "A. Integrity and Confidentiality",
        "C. Purpose Limitation"
      ],
      "correct": 2,
      "justification_correct": "GDPR Article 5(1)(f) establishes 'integrity and confidentiality' as a foundational principle requiring appropriate security measures. ISO 27701 aligns this with confidentiality controls.",
      "justification_wrong": "Lawfulness/fairness (5(1)(a)) addresses legal basis; purpose limitation (5(1)(b)) restricts use; data minimization (5(1)(c)) limits collection—none address security directly."
    },
    {
      "num": 7,
      "text": "A privacy officer discovers that customer consent records lack timestamps and lack clear documentation of consent withdrawal mechanisms. Which privacy governance control is primarily deficient?",
      "tag": "Accountability and Compliance Demonstration",
      "options": [
        "B. Data retention scheduling policies",
        "C. Third-party vendor risk assessment",
        "D. Privacy impact assessment methodology",
        "A. Consent management and audit trail documentation"
      ],
      "correct": 3,
      "justification_correct": "GDPR Article 7 requires demonstrable, documented consent with clear withdrawal rights. NIST Privacy Framework (AU-1) emphasizes audit trails. Timestamps and withdrawal mechanisms constitute mandatory accountability evidence.",
      "justification_wrong": "Retention schedules, vendor assessments, and PIAs are important but don't directly address consent documentation and withdrawal mechanism deficiencies."
    },
    {
      "num": 8,
      "text": "Which ISO 27701 control specifically addresses the requirement to transparently communicate data processing activities to data subjects before collection?",
