    {
      "num": 1,
      "text": "In an investigation of bribes paid to a procurement officer, an examiner obtains a signed statement from a vendor admitting the payments. What type of evidence is this statement?",
      "tag": "Types of Evidence",
      "options": [
        "A. Testimonial evidence",
        "B. Documentary evidence",
        "C. Physical evidence",
        "D. Digital evidence"
      ],
      "correct": 0,
      "justification_correct": "Statements and interviews constitute testimonial evidence — formal accounts provided by individuals regarding facts within their knowledge. (CFE Fraud Examiner Manual 2024)",
      "justification_wrong": "Documentary evidence comprises written records; physical evidence comprises tangible objects; digital evidence comprises electronic data — signed formal statements are classified as testimonial",
      "difficulty": "EASY",
      "legacy": true,
      "legacy_source": "fraud_investigation/quiz_004_en.json"
    },
    {
      "num": 2,
      "text": "An altered purchase order on paper and a series of emails on the server discussing the alteration. How would these two pieces of evidence be categorized, respectively?",
      "tag": "Types of Evidence",
      "options": [
        "A. Testimonial evidence and documentary evidence",
        "B. Physical evidence and digital evidence",
        "C. Direct evidence and circumstantial evidence",
        "D. Primary evidence and secondary evidence"
      ],
      "correct": 1,
      "justification_correct": "The altered purchase order on paper is a tangible item (physical evidence); the emails exist in electronic format (digital evidence) — a fundamental categorization in digital forensics. (CFE Fraud Examiners Manual)",
      "justification_wrong": "Testimonial is a report from people; direct/circumstantial refers to the type of inference needed; primary/secondary is not a standard CFE classification",
      "difficulty": "STANDARD",
      "legacy": true,
      "legacy_source": "fraud_investigation/quiz_004_en.json"
