    {
      "num": 7,
      "text": "When calculating the Beneish M-Score for financial statement fraud detection, which variable specifically measures the extent to which a company is booking revenues before cash is collected?",
      "tag": "Financial Statement Fraud - Beneish M-Score",
      "options": [
        "B. Gross Margin Index (GMI)",
        "D. Sales Growth Index (SGI)",
        "C. Asset Quality Index (AQI)",
        "A. Days Sales in Receivables Index (DSRI)"
      ],
      "correct": 3,
      "justification_correct": "Per CFE Manual 2024, DSRI measures the ratio of days sales in receivables between consecutive years. An increasing DSRI indicates revenue is being recorded faster than cash collection, suggesting potential revenue recognition manipulation. DSRI is calculated as (Net Receivables/Sales)t ÷ (Net Receivables/Sales)t-1.",
      "justification_wrong": "GMI measures declining gross margins indicating cost pressures. AQI measures asset quality deterioration through increased soft assets. SGI measures revenue growth rates. None directly capture the timing difference between revenue recognition and cash collection like DSRI does.",
      "difficulty": "STANDARD",
      "legacy": true,
      "legacy_source": "financial_transactions/quiz_001_en.json"
    },
