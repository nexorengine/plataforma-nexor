  "questions": [
    {
      "num": 1,
      "text": "¿Cuál es la relación correcta entre dato e información en el contexto de la seguridad de la información?",
      "tag": "Conceptos Fundamentales",
      "options": [
        "A. Dato es información estructurada y procesada",
        "B. Información es el significado y el valor atribuido a un conjunto de datos",
        "C. Dato e información son términos intercambiables y equivalentes",
        "D. Información es la forma bruta y no procesada del dato"
      ],
      "correct": 1,
      "justification_correct": "La información resulta de la atribución de significado, contexto y valor a datos brutos — distinción fundamental en la ISO 27000:2018, que define información como datos dotados de relevancia",
      "justification_wrong": "Dato es la forma bruta; información es el dato con significado atribuido. Los términos no son intercambiables en la terminología"
    },
    {
      "num": 2,
      "text": "Para determinar el valor de datos organizacionales con el objetivo de contratación de seguro, ¿cuál factor NO es relevante?",
      "tag": "Valor de la Información",
      "options": [
        "A. El contenido intrínseco del dato",
        "B. La facilidad de recuperación en caso de pérdida, incompletitud o incorreción",
